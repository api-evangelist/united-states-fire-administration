  "info": {
    "_postman_id": "19d4cf7c-e3b5-4087-a079-85345d748f22",
    "name": "OpenFEMA Fire Data API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The OpenFEMA API provides free, read-only access to FEMA and USFA datasets including National Fire Incident Reporting System (NFIRS) annual public data, disaster declarations, FEMA public assistance grants, and other emergency management datasets. No API key is required. The RESTful interface uses query string parameters for filtering, sorting, pagination, and field selection. Base path for all endpoints is https://www.fema.gov/api/open.\n\nContact Support:\n Name: OpenFEMA\n Email: openfema@fema.dhs.gov",
      "type": "text/plain"
    }
  }
